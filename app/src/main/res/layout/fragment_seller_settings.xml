<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_store_settings"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:id="@+id/llViewMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/input_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_store_name"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tvStoreNameDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_dash"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_location"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tvLocationDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_dash"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_status"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tvStatusDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_dash"
                    android:textColor="@color/seller_accent"
                    android:textStyle="bold"
                    android:textSize="16sp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnEditStore"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/action_edit_details"
                android:textColor="@color/white"
                android:backgroundTint="@color/black"
                android:layout_marginTop="24dp"/>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/action_logout_account"
                android:textColor="@color/white"
                android:backgroundTint="@color/delete_red"
                android:layout_marginTop="16dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llEditMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_edit_store_name"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etEditStoreName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:inputType="text"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/input_bg"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_edit_location"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etEditLocation"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:inputType="text"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/input_bg"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_store_status"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <Spinner
                android:id="@+id/spinnerEditStatus"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/input_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnCancelEdit"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/action_cancel"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/input_bg"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnSaveEdit"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/action_save"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/black"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>