<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">


    <androidx.cardview.widget.CardView
        android:id="@+id/cvInboxAvatar"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        app:cardBackgroundColor="#EEEEEE"
        app:cardCornerRadius="25dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/ivInboxAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"

            android:src="@drawable/profile_user_pic"
            />
    </androidx.cardview.widget.CardView>



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="12dp"

        android:layout_toEndOf="@id/cvInboxAvatar"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvInboxPartnerId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buyer123"
            android:textColor="#222222"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvInboxLastMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Is this still available?"
            android:textColor="#757575"
            android:textSize="14sp" />
    </LinearLayout>

</RelativeLayout>